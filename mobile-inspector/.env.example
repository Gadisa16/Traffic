# Mobile Inspector (Expo)
# Create a local file named .env (DO NOT commit it)

# Backend API (set to local machine IP)
EXPO_PUBLIC_API_URL=http://192.168.43.240:8000

# Client-safe Supabase settings (OK to ship in the app)
EXPO_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=<client-anon-key>

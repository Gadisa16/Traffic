# Backend environment (DO NOT put real secrets in this file when committing)

# Database
# Local dev (SQLite)
# DATABASE_URL=sqlite:///./test.db

# Supabase Postgres (recommended)
# IMPORTANT: use the Transaction Pooler or Direct Connection string from Supabase.
# Example (direct):
DATABASE_URL=postgresql+psycopg://postgres:<db_password>@db.<project_ref>.supabase.co:5432/postgres?sslmode=require

# Auth / bootstrap
ALLOW_REGISTRATION=false
DEV_OTP_CODE=123456

# Admin signup & verification
# Set to "true" to enable admin registration via /auth/admin/register
# First admin becomes super_admin automatically
# Subsequent admins become unverified_admin (read-only until verified by existing admin)
ALLOW_ADMIN_REGISTRATION=false

# Storage
# Set to "supabase" to force Supabase even if env detection fails
# STORAGE_DRIVER=supabase

# Signed URL TTL for private buckets
SUPABASE_SIGNED_URL_TTL_SECONDS=3600

# Bucket names (create these as PRIVATE buckets in Supabase Storage)
# - qr-codes
# - vehicle-photos
# - inspector-docs
# - owner-docs

# Legacy fallback bucket (not used when bucket is passed explicitly)
SUPABASE_STORAGE_BUCKET=traffic-files

# Supabase (SERVER ONLY)
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<server-only-service-role-key>

# Optional: override for public URL base if you use a custom domain/CDN
# SUPABASE_PUBLIC_BASE_URL=https://<your-project-ref>.supabase.co

# FastAPI Backend URL
VITE_API_URL=http://localhost:8000

# Admin signup control
# Set to "true" to enable admin registration UI
# Backend must also have ALLOW_ADMIN_REGISTRATION=true
VITE_ENABLE_ADMIN_SIGNUP=true

# Supabase (optional, for storage only if needed)
# VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co
# VITE_SUPABASE_PUBLISHABLE_KEY=<your-anon-key>
